<?xml version="1.0" encoding="utf-8"?>

<views:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MotionLink.Views"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="MotionLink.Views.HistoryView"
    x:Name="historyPage"
    Title="Session History">
    <Grid RowDefinitions="Auto, *">
        <ScrollView Grid.Row="1" Padding="15">
            <VerticalStackLayout Spacing="15">
                <Border Padding="6"
                BackgroundColor="#E3F2FD"
                StrokeThickness="0"
                Margin="0,6,0,0"
                StrokeShape="RoundRectangle 6">
                    <Label Text="{Binding Histories.Count, StringFormat='Sessions: {0}'}"
                    FontAttributes="Bold"
                    FontSize="12"
                    TextColor="#1565C0" />
                </Border>
                <VerticalStackLayout Spacing="10">
                    <CollectionView ItemsSource="{Binding Histories}"                         
                        SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding NavigateToSelectedDetailCommand}" Margin="0,10">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" Padding="40">
                                <Label Text="No sessions yet..." HorizontalOptions="Center" TextColor="Gray" />
                                <Button Text="Open Dashboard"
                                        Command="{Binding NavigateToDashboardCommand}"
                                        Margin="0,20" BackgroundColor="#4CAF50" HeightRequest="60" CornerRadius="30" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.LeftItems>
                                            <SwipeItems>
                                            <SwipeItemView
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type views:HistoryView}}, Path=BindingContext.DeleteSessionCommand}"
                                                CommandParameter="{Binding .}">
                                                <Border
                                                    BackgroundColor="Red"
                                                    Padding="14"
                                                    StrokeShape="RoundRectangle 12">
                                                <Label Text="Delete"
                                                    TextColor="White"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Start" />
                                                </Border>
                                            </SwipeItemView>

                                        </SwipeItems>
                                     </SwipeView.LeftItems>
                                    <Border Margin="0,8"
                                        Padding="14"
                                        Stroke="#CCCCCC"
                                        StrokeThickness="1.5"
                                        BackgroundColor="#FFFFFF"
                                        StrokeShape="RoundRectangle 12">
                                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                                            <BoxView WidthRequest="6"
                                                 BackgroundColor="#1E88E5"
                                                 CornerRadius="3"
                                                 VerticalOptions="Fill" />

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">

                                                <Label Text="{Binding Name, FallbackValue='Unnamed Session'}"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   TextColor="#1E1E1E" />

                                                <HorizontalStackLayout Spacing="10">
                                                    <Label Text="Start:"
                                                       FontSize="11"
                                                       TextColor="#777" />
                                                    <Label Text="{Binding DateStart, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       FontSize="11"
                                                       TextColor="#444" />
                                                </HorizontalStackLayout>

                                                <HorizontalStackLayout Spacing="10">
                                                    <Label Text="End:"
                                                       FontSize="11"
                                                       TextColor="#777" />
                                                    <Label Text="{Binding DateEnd, TargetNullValue='--', StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       FontSize="11"
                                                       TextColor="#444" />
                                                </HorizontalStackLayout>

                                                <Border Padding="6"
                                                   BackgroundColor="#E3F2FD"
                                                   StrokeThickness="0"
                                                   Margin="0,6,0,0"
                                                   StrokeShape="RoundRectangle 6">
                                                    <Label Text="{Binding SwingCount, StringFormat='Swings: {0}'}"
                                                       FontAttributes="Bold"
                                                       FontSize="12"
                                                       TextColor="#1565C0" />
                                                </Border>

                                            </VerticalStackLayout>

                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>

                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</views:BaseContentPage>