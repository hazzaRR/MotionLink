<?xml version="1.0" encoding="utf-8"?>

<views:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       xmlns:views="clr-namespace:MotionLink.Views"
                       x:Class="MotionLink.Views.SensorDisplayView"
                       xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                       xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
                       Title="Swing Session">

    <views:BaseContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <Style x:Key="StatCard" TargetType="Frame">
                <!-- <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F0F0, Dark=#2C2C2C}" /> -->
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Padding" Value="15" />
                <Setter Property="BorderColor" Value="Transparent" />
            </Style>
        </ResourceDictionary>
    </views:BaseContentPage.Resources>

    <Grid RowDefinitions="Auto, *">

        <Frame Grid.Row="0" Margin="10" Padding="10" BackgroundColor="#1E1E1E" CornerRadius="0">
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <!-- <Ellipse WidthRequest="12" HeightRequest="12"
                         Fill="{Binding BleService.IsConnected, Converter={StaticResource ConnectionColorConverter}}" /> -->
                <Label Text="{Binding BleService.ConnectedPeripheral.Name, FallbackValue='No Device'}"
                       TextColor="White" VerticalOptions="Center" FontAttributes="Bold" />
            </HorizontalStackLayout>
        </Frame>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="20">

                <VerticalStackLayout Spacing="15"
                                     IsVisible="{Binding BleService.IsConnected, Converter={StaticResource InvertedBoolConverter}}">
                    <!-- <Image Source="no_connection.png" HeightRequest="100" Opacity="0.5" /> -->
                    <Label HorizontalOptions="Center" Text="Motion Link device not found" FontSize="18" />
                    <Button Text="Connect Sensor" Command="{Binding NavigateToConnectCommand}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="20" IsVisible="{Binding BleService.IsConnected}">

                    <FlexLayout JustifyContent="SpaceBetween" Wrap="Wrap">
                        <Frame Style="{StaticResource StatCard}" WidthRequest="160" Margin="0,0,0,10">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="PEAK SPEED" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                                <Label Text="{Binding BleService.PeakRotation, StringFormat='{0:F0}°/s'}"
                                       FontSize="24" FontAttributes="Bold" TextColor="#2196F3" />
                            </VerticalStackLayout>
                        </Frame>

                        <Frame Style="{StaticResource StatCard}" WidthRequest="160" Margin="0,0,0,10">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="MAX FORCE" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                                <Label Text="{Binding BleService.PeakGForce, StringFormat='{0:F1} G'}"
                                       FontSize="24" FontAttributes="Bold" TextColor="#F44336" />
                            </VerticalStackLayout>
                        </Frame>
                    </FlexLayout>

                    <VerticalStackLayout Spacing="5" IsVisible="{Binding IsCapturing}">
                        <Label Text="Accelerometer (Linear Motion)" FontAttributes="Bold" Margin="5,0" />
                        <Frame Padding="0" HeightRequest="220" HasShadow="False" BackgroundColor="Transparent">
                            <lvc:CartesianChart Series="{Binding BleService.AccelSeries}"
                                                SyncContext="{Binding BleService.Sync}"
                                                TooltipPosition="Hidden" />
                        </Frame>

                        <Label Text="Gyroscope (Rotation)" FontAttributes="Bold" Margin="5,15,5,0" />
                        <Frame Padding="0" HeightRequest="220" HasShadow="False" BackgroundColor="Transparent">
                            <lvc:CartesianChart Series="{Binding BleService.GyroSeries}"
                                                SyncContext="{Binding BleService.Sync}"
                                                TooltipPosition="Hidden" />
                        </Frame>

                        <Label Text="Quaternion" FontAttributes="Bold" Margin="5,15,5,0" />
                        <Frame Padding="0" HeightRequest="220" HasShadow="False" BackgroundColor="Transparent">
                            <lvc:CartesianChart Series="{Binding BleService.QuaternionSeries}"
                                                SyncContext="{Binding BleService.Sync}"
                                                TooltipPosition="Hidden" />
                        </Frame>
                    </VerticalStackLayout>

                    <Button Text="Start Swing Capture"
                            Command="{Binding CaptureDataCommand}"
                            IsVisible="{Binding IsCapturing, Converter={StaticResource InvertedBoolConverter}}"
                            CornerRadius="25" HeightRequest="50" />

                    <Button Text="Stop &amp; Save Session"
                            Command="{Binding PauseDataCommand}"
                            IsVisible="{Binding IsCapturing}"
                            BackgroundColor="#D32F2F" CornerRadius="25" HeightRequest="50" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</views:BaseContentPage>