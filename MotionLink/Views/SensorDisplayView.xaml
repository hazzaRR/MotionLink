<?xml version="1.0" encoding="utf-8" ?>
<views:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:MotionLink.Views"
             x:Class="MotionLink.Views.SensorDisplayView"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Toolkit.Charts;assembly=Syncfusion.Maui.Toolkit">

<views:BaseContentPage.Resources>
    <ResourceDictionary>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ResourceDictionary>
</views:BaseContentPage.Resources>
<ScrollView Margin="20">
    <VerticalStackLayout>
        <VerticalStackLayout HorizontalOptions="Center" Padding="10" Margin="10" IsVisible="{Binding BleService.IsConnected, Converter={StaticResource InvertedBoolConverter}}">
            <Label HorizontalOptions="Center" Text="No device is currently connected" />

            <Button Text="Find Device" Command="{Binding NavigateToConnectCommand}" />

        </VerticalStackLayout>
        <VerticalStackLayout HorizontalOptions="Center" Padding="10" Margin="10" IsVisible="{Binding BleService.IsConnected}">
            <Label Text="{Binding BleService.ConnectedPeripheral.Uuid}" FontSize="10" />
            <Label Text="{Binding BleService.LastValue.Ax}" IsVisible="{Binding IsCapturing}" FontSize="10" />
            <Label Text="{Binding BleService.LastValue.Ay}" IsVisible="{Binding IsCapturing}" FontSize="10" />
            <Label Text="{Binding BleService.LastValue.Az}" IsVisible="{Binding IsCapturing}" FontSize="10" />
            <Label Text="{Binding BleService.LastValue.Gx}" IsVisible="{Binding IsCapturing}" FontSize="10" />
            <Label Text="{Binding BleService.LastValue.Gy}" IsVisible="{Binding IsCapturing}" FontSize="10" />
            <Label Text="{Binding BleService.LastValue.Gz}" IsVisible="{Binding IsCapturing}" FontSize="10" />
